generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIALLY_PAID
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MOMO
  ZALOPAY
  VNPAY
  PAYPAL
  CARD
}

enum PaymentIntentStatus {
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentAttemptStatus {
  CREATED
  REDIRECT_REQUIRED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentSignalSource {
  INITIATION
  CALLBACK
  WEBHOOK
  SYSTEM
}

enum PaymentIntentEventType {
  INTENT_CREATED
  ATTEMPT_CREATED
  SIGNAL_RECEIVED
  VERIFICATION_PASSED
  VERIFICATION_FAILED
  STATE_TRANSITION
  PAYMENT_RECORDED
  MANUAL_REVIEW_REQUIRED
}

model Invoice {
  id                 String        @id @default(uuid())
  invoiceNumber      String        @unique
  studentId          String
  studentUserId      String
  studentDisplayName String
  studentEmail       String
  studentCode        String
  semesterId         String
  semesterName       String
  semesterNameEn     String?
  semesterNameVi     String?
  status             InvoiceStatus @default(DRAFT)
  subtotal           Decimal       @db.Decimal(10, 2)
  discount           Decimal       @default(0) @db.Decimal(10, 2)
  total              Decimal       @db.Decimal(10, 2)
  dueDate            DateTime
  paidAt             DateTime?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  items          InvoiceItem[]
  payments       Payment[]
  paymentIntents PaymentIntent[]

  @@index([invoiceNumber])
  @@index([studentId])
  @@index([studentUserId])
  @@index([semesterId])
  @@index([status])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id              String        @id @default(uuid())
  paymentNumber   String        @unique
  invoiceId       String
  studentId       String
  amount          Decimal       @db.Decimal(10, 2)
  method          String
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  transactionId   String?
  paymentIntentId String?       @unique
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentIntent PaymentIntent? @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)

  @@index([paymentNumber])
  @@index([invoiceId])
  @@index([studentId])
  @@index([status])
}

model PaymentIntent {
  id           String              @id @default(uuid())
  intentNumber String              @unique
  invoiceId    String
  studentId    String
  provider     PaymentProvider
  status       PaymentIntentStatus @default(REQUIRES_ACTION)
  amount       Decimal             @db.Decimal(10, 2)
  currency     String              @default("VND")
  metadata     Json?
  expiresAt    DateTime
  lastSignalAt DateTime?
  finalizedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  invoice  Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  payment  Payment?
  attempts PaymentAttempt[]
  events   PaymentIntentEvent[]

  @@index([invoiceId])
  @@index([studentId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model PaymentAttempt {
  id                String               @id @default(uuid())
  attemptNumber     String               @unique
  intentId          String
  invoiceId         String
  studentId         String
  provider          PaymentProvider
  status            PaymentAttemptStatus @default(CREATED)
  idempotencyKey    String
  publicToken       String               @unique
  amount            Decimal              @db.Decimal(10, 2)
  currency          String               @default("VND")
  providerReference String?
  redirectUrl       String?
  callbackUrl       String?
  webhookUrl        String?
  returnUrl         String?
  cancelUrl         String?
  providerPayload   Json?
  occurredAt        DateTime?
  finalizedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  intent PaymentIntent        @relation(fields: [intentId], references: [id], onDelete: Restrict)
  events PaymentIntentEvent[]

  @@unique([invoiceId, studentId, provider, idempotencyKey])
  @@index([intentId])
  @@index([status])
  @@index([createdAt])
}

model PaymentIntentEvent {
  id                String                 @id @default(uuid())
  paymentIntentId   String
  paymentAttemptId  String?
  type              PaymentIntentEventType
  source            PaymentSignalSource
  provider          PaymentProvider
  fromIntentStatus  PaymentIntentStatus?
  toIntentStatus    PaymentIntentStatus?
  fromAttemptStatus PaymentAttemptStatus?
  toAttemptStatus   PaymentAttemptStatus?
  payload           Json?
  createdAt         DateTime               @default(now())

  intent  PaymentIntent   @relation(fields: [paymentIntentId], references: [id], onDelete: Restrict)
  attempt PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: Restrict)

  @@index([paymentIntentId, createdAt])
  @@index([paymentAttemptId, createdAt])
  @@index([type])
  @@index([source])
}

model Scholarship {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  type        String
  value       Decimal  @db.Decimal(10, 2)
  criteria    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentScholarships StudentScholarship[]
}

model StudentScholarship {
  id            String    @id @default(uuid())
  studentId     String
  scholarshipId String
  semesterId    String?
  startDate     DateTime
  endDate       DateTime?
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([studentId, scholarshipId, semesterId])
  @@index([studentId])
  @@index([scholarshipId])
  @@index([semesterId])
}
