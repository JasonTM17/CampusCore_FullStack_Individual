generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  LOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SemesterStatus {
  DRAFT
  ACTIVE
  REGISTRATION_OPEN
  ADD_DROP_OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  DROPPED
  COMPLETED
  CANCELLED
}

enum GradeStatus {
  DRAFT
  PUBLISHED
  APPEALED
}

enum WaitlistStatus {
  ACTIVE
  CONVERTED
  EXPIRED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  firstName   String
  lastName    String
  phone       String?
  gender      Gender?
  dateOfBirth DateTime?
  address     String?
  avatar      String?
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  student  Student?
  lecturer Lecturer?

  @@index([email])
  @@index([status])
}

model Faculty {
  id          String   @id @default(uuid())
  name        String
  nameEn      String?
  nameVi      String?
  code        String   @unique
  description String?
  descriptionEn String?
  descriptionVi String?
  dean        String?
  phone       String?
  email       String?
  building    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  departments Department[]

  @@index([code])
}

model Department {
  id          String   @id @default(uuid())
  name        String
  nameEn      String?
  nameVi      String?
  code        String   @unique
  description String?
  descriptionEn String?
  descriptionVi String?
  chair       String?
  phone       String?
  email       String?
  building    String?
  facultyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  faculty   Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  courses   Course[]
  curricula Curriculum[]
  lecturers Lecturer[]

  @@index([code])
  @@index([facultyId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  year      Int
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  semesters Semester[]
  curricula Curriculum[]

  @@unique([year])
  @@index([isCurrent])
}

model Semester {
  id                String         @id @default(uuid())
  name              String
  nameEn            String?
  nameVi            String?
  type              String
  academicYearId    String
  startDate         DateTime
  endDate           DateTime
  registrationStart DateTime?
  registrationEnd   DateTime?
  addDropStart      DateTime?
  addDropEnd        DateTime?
  status            SemesterStatus @default(DRAFT)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  courses      Course[]
  sections     Section[]
  enrollments  Enrollment[]
  curricula    Curriculum[]

  @@unique([academicYearId, type])
  @@index([status])
  @@index([academicYearId])
}

model Course {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  nameEn       String?
  nameVi       String?
  description  String?
  descriptionEn String?
  descriptionVi String?
  credits      Int
  departmentId String
  semesterId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semester   Semester?  @relation(fields: [semesterId], references: [id], onDelete: SetNull)

  prerequisites     CoursePrerequisite[] @relation("CoursePrerequisites")
  requiredBy        CoursePrerequisite[] @relation("RequiredByCourses")
  curriculumCourses CurriculumCourse[]
  sections          Section[]
  gradeItems        GradeItem[]

  @@index([code])
  @@index([departmentId])
  @@index([semesterId])
}

model CoursePrerequisite {
  id             String   @id @default(uuid())
  courseId       String
  prerequisiteId String
  isCorequisite  Boolean  @default(false)
  createdAt      DateTime @default(now())

  course       Course @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite Course @relation("RequiredByCourses", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteId])
  @@index([courseId])
  @@index([prerequisiteId])
}

model Curriculum {
  id             String   @id @default(uuid())
  name           String
  nameEn         String?
  nameVi         String?
  code           String   @unique
  departmentId   String
  academicYearId String
  semesterId     String?
  totalCredits   Int
  description    String?
  descriptionEn  String?
  descriptionVi  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semester     Semester?    @relation(fields: [semesterId], references: [id], onDelete: SetNull)

  courses  CurriculumCourse[]
  students Student[]

  @@index([code])
  @@index([departmentId])
  @@index([academicYearId])
  @@index([semesterId])
}

model CurriculumCourse {
  id           String  @id @default(uuid())
  curriculumId String
  courseId     String
  year         Int
  semester     Int
  isMandatory  Boolean @default(true)

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([curriculumId, courseId])
  @@index([curriculumId])
  @@index([courseId])
}

model Lecturer {
  id             String   @id @default(uuid())
  userId         String   @unique
  departmentId   String
  employeeId     String   @unique
  title          String?
  specialization String?
  office         String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isActive       Boolean  @default(true)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  sections   Section[]

  @@index([employeeId])
  @@index([departmentId])
}

model Student {
  id            String   @id @default(uuid())
  userId        String   @unique
  studentId     String   @unique
  curriculumId  String
  year          Int
  status        String   @default("ACTIVE")
  admissionDate DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  enrollments Enrollment[]
  attendances Attendance[]
  waitlists   Waitlist[]

  @@index([studentId])
  @@index([curriculumId])
}

model Classroom {
  id         String   @id @default(uuid())
  building   String
  roomNumber String
  capacity   Int
  type       String
  equipment  String[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sections  Section[]
  schedules SectionSchedule[]

  @@unique([building, roomNumber])
  @@index([building])
}

model Section {
  id            String   @id @default(uuid())
  sectionNumber String
  courseId      String
  semesterId    String
  lecturerId    String?
  classroomId   String?
  capacity      Int
  enrolledCount Int      @default(0)
  status        String   @default("OPEN")
  maxCredits    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semester  Semester   @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  lecturer  Lecturer?  @relation(fields: [lecturerId], references: [id], onDelete: SetNull)
  classroom Classroom? @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  schedules   SectionSchedule[]
  enrollments Enrollment[]
  waitlists   Waitlist[]
  gradeItems  GradeItem[]
  attendances Attendance[]

  @@unique([courseId, semesterId, sectionNumber])
  @@index([courseId])
  @@index([semesterId])
  @@index([lecturerId])
  @@index([classroomId])
}

model SectionSchedule {
  id          String @id @default(uuid())
  sectionId   String
  classroomId String
  dayOfWeek   Int
  startTime   String
  endTime     String

  section   Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([classroomId, dayOfWeek])
}

model Enrollment {
  id          String           @id @default(uuid())
  studentId   String
  sectionId   String
  semesterId  String
  status      EnrollmentStatus @default(PENDING)
  enrolledAt  DateTime         @default(now())
  droppedAt   DateTime?
  gradeStatus GradeStatus      @default(DRAFT)
  finalGrade  Decimal?         @db.Decimal(5, 2)
  letterGrade String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  semester Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  gradeItems StudentGrade[]

  @@unique([studentId, sectionId])
  @@index([studentId])
  @@index([sectionId])
  @@index([semesterId])
  @@index([status])
}

model Waitlist {
  id          String         @id @default(uuid())
  studentId   String
  sectionId   String
  position    Int
  status      WaitlistStatus @default(ACTIVE)
  addedAt     DateTime       @default(now())
  convertedAt DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, studentId])
  @@index([sectionId, position])
  @@index([studentId])
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  sectionId String
  date      DateTime
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId, date])
  @@index([studentId])
  @@index([sectionId])
  @@index([date])
}

model GradeItem {
  id        String    @id @default(uuid())
  sectionId String
  name      String
  type      String
  maxScore  Decimal   @db.Decimal(5, 2)
  weight    Decimal   @db.Decimal(5, 2)
  gradedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  courseId  String?

  section Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  course  Course?        @relation(fields: [courseId], references: [id])
  grades  StudentGrade[]

  @@index([sectionId])
  @@index([courseId])
}

model StudentGrade {
  id           String   @id @default(uuid())
  gradeItemId  String
  enrollmentId String
  score        Decimal? @db.Decimal(5, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gradeItem  GradeItem  @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([gradeItemId, enrollmentId])
  @@index([gradeItemId])
  @@index([enrollmentId])
}
