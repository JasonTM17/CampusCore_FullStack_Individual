# Public site URL used for canonical metadata, sitemap, and manifest generation.
NEXT_PUBLIC_SITE_URL=https://tienson.io.vn

# Default API base path for browser requests. Keep this relative in local and edge setups.
NEXT_PUBLIC_API_URL=/api/v1

# Local edge origin used by next dev rewrites so auth and public API calls behave like the real edge.
LOCAL_EDGE_ORIGIN=http://127.0.0.1:8080

# Optional: enable local edge rewrites for a standalone local preview after `npm run build`.
ENABLE_LOCAL_EDGE_REWRITES=0
