// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
  LOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  REGISTRAR
  FINANCE_OFFICER
  LECTURER
  STUDENT
  GUEST
}

enum SemesterStatus {
  DRAFT
  ACTIVE
  REGISTRATION_OPEN
  ADD_DROP_OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  DROPPED
  COMPLETED
  CANCELLED
}

enum GradeStatus {
  DRAFT
  PUBLISHED
  APPEALED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIALLY_PAID
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WaitlistStatus {
  ACTIVE
  CONVERTED
  EXPIRED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// Models

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  gender            Gender?
  dateOfBirth       DateTime?
  address           String?
  avatar            String?
  status            UserStatus @default(ACTIVE)
  emailVerified     Boolean   @default(false)
  isSuperAdmin      Boolean   @default(false)
  failedLoginAttempts Int     @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  refreshToken      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  student           Student?
  lecturer          Lecturer?
  roles             UserRole[]
  sessions          Session[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  supportTickets    SupportTicket[]

  @@index([email])
  @@index([status])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model Role {
  id          String     @id @default(uuid())
  name        RoleName   @unique
  description String?
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  module      String
  action      String
  createdAt   DateTime         @default(now())

  roles       RolePermission[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model Faculty {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  dean        String?
  phone       String?
  email       String?
  building    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  departments Department[]
  courses     Course[]

  @@index([code])
}

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  chair       String?
  phone       String?
  email       String?
  building    String?
  facultyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  faculty     Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  courses     Course[]
  curricula   Curriculum[]
  lecturers   Lecturer[]

  @@index([code])
  @@index([facultyId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  year      Int
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  semesters Semester[]

  @@unique([year])
  @@index([isCurrent])
}

model Semester {
  id              String         @id @default(uuid())
  name            String
  type            String         // FALL, SPRING, SUMMER
  academicYearId  String
  startDate       DateTime
  endDate         DateTime
  registrationStart DateTime?
  registrationEnd   DateTime?
  addDropStart      DateTime?
  addDropEnd        DateTime?
  status          SemesterStatus @default(DRAFT)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  courses         Course[]
  curricula       Curriculum[]
  sections        Section[]
  enrollments     Enrollment[]
  invoices        Invoice[]
  announcements   Announcement[]

  @@unique([academicYearId, type])
  @@index([status])
  @@index([academicYearId])
}

model Course {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  description     String?
  credits         Int
  departmentId    String
  semesterId      String?  // Suggested semester in curriculum
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semester        Semester?      @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  faculty         Faculty?        @relation(fields: [departmentId], references: [id]) // denormalized for easier queries

  prerequisites   CoursePrerequisite[] @relation("CoursePrerequisites")
  requiredBy      CoursePrerequisite[] @relation("RequiredByCourses")
  curriculumCourses CurriculumCourse[]
  sections        Section[]
  gradeItems      GradeItem[]
  
  @@index([code])
  @@index([departmentId])
}

model CoursePrerequisite {
  id            String   @id @default(uuid())
  courseId      String
  prerequisiteId String
  isCorequisite Boolean  @default(false)
  createdAt     DateTime @default(now())

  course        Course   @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite  Course   @relation("RequiredByCourses", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteId])
  @@index([courseId])
  @@index([prerequisiteId])
}

model Curriculum {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  departmentId String
  academicYearId String
  totalCredits Int
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  courses      CurriculumCourse[]
  students     Student[]

  @@index([code])
  @@index([departmentId])
}

model CurriculumCourse {
  id           String  @id @default(uuid())
  curriculumId String
  courseId     String
  year         Int     // Year in curriculum (1, 2, 3, 4)
  semester     Int     // Semester (1, 2)
  isMandatory  Boolean @default(true)

  curriculum   Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([curriculumId, courseId])
  @@index([curriculumId])
  @@index([courseId])
}

model Lecturer {
  id           String   @id @default(uuid())
  userId       String    @unique
  departmentId String
  employeeId  String    @unique
  title       String?
  specialization String?
  office      String?
  phone       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isActive    Boolean   @default(true)

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  sections     Section[]
  announcements Announcement[]

  @@index([employeeId])
  @@index([departmentId])
}

model Student {
  id           String   @id @default(uuid())
  userId       String    @unique
  studentId    String    @unique
  curriculumId String
  year         Int      // Current year in curriculum
  status       String   @default("ACTIVE") // ACTIVE, GRADUATED, SUSPENDED, WITHDRAWN
  admissionDate DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  curriculum   Curriculum  @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  enrollments  Enrollment[]
  attendances  Attendance[]
  waitlists    Waitlist[]
  invoices     Invoice[]
  payments     Payment[]

  @@index([studentId])
  @@index([curriculumId])
}

model Classroom {
  id          String   @id @default(uuid())
  building    String
  roomNumber  String
  capacity    Int
  type        String   // LECTURE, LAB, SEMINAR
  equipment   String[] // Projector, Computer, Whiteboard, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections    Section[]
  schedules   SectionSchedule[]

  @@unique([building, roomNumber])
  @@index([building])
}

model Section {
  id           String   @id @default(uuid())
  sectionNumber String
  courseId     String
  semesterId  String
  lecturerId   String?
  classroomId String?
  capacity    Int
  enrolledCount Int     @default(0)
  status       String   @default("OPEN") // OPEN, CLOSED, CANCELLED
  maxCredits   Int?     // Override for this section
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semester     Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  lecturer     Lecturer?    @relation(fields: [lecturerId], references: [id], onDelete: SetNull)
  classroom    Classroom?   @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  schedules    SectionSchedule[]
  enrollments  Enrollment[]
  waitlists    Waitlist[]
  gradeItems   GradeItem[]
  announcements Announcement[]

  @@unique([courseId, semesterId, sectionNumber])
  @@index([courseId])
  @@index([semesterId])
  @@index([lecturerId])
}

model SectionSchedule {
  id          String   @id @default(uuid())
  sectionId   String
  classroomId String
  dayOfWeek   Int      // 0=Sunday, 1=Monday, etc.
  startTime   String   // HH:mm format
  endTime     String   // HH:mm format

  section     Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  classroom   Classroom  @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@index([classroomId, dayOfWeek])
}

model Enrollment {
  id          String          @id @default(uuid())
  studentId   String
  sectionId   String
  status      EnrollmentStatus @default(PENDING)
  enrolledAt  DateTime        @default(now())
  droppedAt   DateTime?
  gradeStatus GradeStatus     @default(DRAFT)
  finalGrade  Decimal?        @db.Decimal(5,2)
  letterGrade String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section     Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  attendance  Attendance[]
  gradeItems   GradeItem[]

  @@unique([studentId, sectionId])
  @@index([studentId])
  @@index([sectionId])
  @@index([status])
}

model Waitlist {
  id         String        @id @default(uuid())
  studentId  String
  sectionId  String
  position   Int
  status     WaitlistStatus @default(ACTIVE)
  addedAt    DateTime      @default(now())
  convertedAt DateTime?

  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section    Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, studentId])
  @@index([sectionId, position])
  @@index([studentId])
}

model Attendance {
  id          String         @id @default(uuid())
  studentId   String
  sectionId   String
  date        DateTime
  status      AttendanceStatus
  notes       String?
  createdAt   DateTime       @default(now())

  student     Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section     Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  enrollment  Enrollment?    @relation(fields: [studentId, sectionId], references: [studentId, sectionId])

  @@unique([studentId, sectionId, date])
  @@index([studentId])
  @@index([sectionId])
  @@index([date])
}

model GradeItem {
  id          String   @id @default(uuid())
  sectionId   String
  name        String
  type        String   // QUIZ, MIDTERM, FINAL, ASSIGNMENT, PROJECT
  maxScore    Decimal  @db.Decimal(5,2)
  weight      Decimal  @db.Decimal(5,2)
  gradedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section     Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  grades      StudentGrade[]

  @@index([sectionId])
}

model StudentGrade {
  id          String   @id @default(uuid())
  gradeItemId String
  enrollmentId String
  score       Decimal? @db.Decimal(5,2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gradeItem   GradeItem  @relation(fields: [gradeItemId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([gradeItemId, enrollmentId])
  @@index([gradeItemId])
  @@index([enrollmentId])
}

model Invoice {
  id          String       @id @default(uuid())
  invoiceNumber String     @unique
  studentId   String
  semesterId  String
  status      InvoiceStatus @default(DRAFT)
  subtotal    Decimal      @db.Decimal(10,2)
  discount    Decimal      @default(0) @db.Decimal(10,2)
  total       Decimal      @db.Decimal(10,2)
  dueDate     DateTime
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semester    Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  items       InvoiceItem[]
  payments    Payment[]

  @@index([invoiceNumber])
  @@index([studentId])
  @@index([semesterId])
  @@index([status])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10,2)
  total       Decimal  @db.Decimal(10,2)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id            String        @id @default(uuid())
  paymentNumber String        @unique
  invoiceId     String
  studentId     String
  amount        Decimal       @db.Decimal(10,2)
  method        String        // CASH, CARD, BANK_TRANSFER
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  transactionId String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([paymentNumber])
  @@index([invoiceId])
  @@index([studentId])
  @@index([status])
}

model Scholarship {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  type        String   // PERCENTAGE, FIXED_AMOUNT
  value       Decimal  @db.Decimal(10,2)
  criteria    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentScholarships StudentScholarship[]
}

model StudentScholarship {
  id             String   @id @default(uuid())
  studentId      String
  scholarshipId  String
  semesterId     String?
  startDate      DateTime
  endDate        DateTime?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student        Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scholarship    Scholarship  @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  semester       Semester?   @relation(fields: [semesterId], references: [id], onDelete: SetNull)

  @@unique([studentId, scholarshipId, semesterId])
  @@index([studentId])
  @@index([scholarshipId])
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  targetRoles String[] // Which roles can see this
  targetYears Int[]?  // Which years (for students)
  isGlobal    Boolean  @default(false)
  publishAt   DateTime?
  expiresAt   DateTime?
  publishedBy String?
  semesterId  String?
  sectionId   String?
  lecturerId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  semester    Semester?  @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  section     Section?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  lecturer    Lecturer?  @relation(fields: [lecturerId], references: [id], onDelete: SetNull)

  @@index([priority])
  @@index([semesterId])
  @@index([sectionId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // INFO, WARNING, ERROR, SUCCESS
  link      String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  description String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model SupportTicket {
  id          String        @id @default(uuid())
  ticketNumber String        @unique
  userId      String
  subject     String
  description String
  category    String        // ACADEMIC, FINANCE, TECHNICAL, OTHER
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus  @default(OPEN)
  assignedTo  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   TicketResponse[]

  @@index([ticketNumber])
  @@index([userId])
  @@index([status])
  @@index([priority])
}

model TicketResponse {
  id          String   @id @default(uuid())
  ticketId    String
  userId      String
  message     String
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([userId])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  category    String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}
