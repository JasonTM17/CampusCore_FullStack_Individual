# Database
DATABASE_URL=postgresql://campuscore:your_password@localhost:5432/campuscore

# JWT
JWT_SECRET=change-this-jwt-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3000
NODE_ENV=production

# Email / SMTP Configuration
# SMTP Settings (optional - if not configured, emails will be logged only in development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SECURE=false

# Email Settings
EMAIL_FROM=noreply@campuscore.edu
EMAIL_FROM_NAME=CampusCore Administration
FRONTEND_URL=http://localhost:3001

# Password Reset
PASSWORD_RESET_EXPIRY_MINUTES=15

# File Upload
FILE_BASE_URL=http://localhost:4000/uploads
