NODE_ENV=development
PORT=4001
DATABASE_URL=postgresql://campuscore:campuscore_password@localhost:5432/campuscore?schema=notifications
FRONTEND_URL=http://localhost
JWT_SECRET=change-me-access-secret
COOKIE_SECURE=false
HEALTH_READINESS_KEY=change-me-readiness-key
RABBITMQ_URL=amqp://campuscore:campuscore_password@localhost:5672

# Outbound email. Use private env/secret storage for real credentials.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=replace-with-private-app-password
EMAIL_FROM=your-smtp-user@example.com
EMAIL_FROM_NAME=CampusCore Administration
