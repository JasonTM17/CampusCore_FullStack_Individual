DATABASE_URL=postgresql://campuscore:campuscore_password@postgres:5432/campuscore
FRONTEND_URL=http://localhost
# Generate long random secrets before any shared or production deployment.
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
HEALTH_READINESS_KEY=replace-with-a-long-random-readiness-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SWAGGER_ENABLED=false
COOKIE_SECURE=false
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://campuscore:campuscore_password@rabbitmq:5672
EMAIL_FROM=noreply@campuscore.edu
EMAIL_FROM_NAME=CampusCore Administration
PASSWORD_RESET_EXPIRY_MINUTES=15
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=campuscore
MINIO_ACCESS_KEY=campuscore
MINIO_SECRET_KEY=campuscore_password
LOG_LEVEL=info
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
PORT=4000
NODE_ENV=production
