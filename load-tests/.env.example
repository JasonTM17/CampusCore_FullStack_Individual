# CampusCore Load Testing Environment Variables
# Copy this to .env and update with your values

# Base URLs
BASE_URL=http://localhost
API_BASE_URL=http://localhost/api/v1

# Test User Credentials (Student)
K6_USERS_EMAIL=student1@campuscore.edu
K6_USERS_PASSWORD=password123

# Admin Credentials
K6_ADMIN_EMAIL=admin@campuscore.edu
K6_ADMIN_PASSWORD=admin123

# Optional: Semester IDs for testing
# K6_SEMESTER_IDS=semester-id-1,semester-id-2

# Optional: Request timeout (ms)
# TIMEOUT=30000
